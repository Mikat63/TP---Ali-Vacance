  </h2>

  <!-- FORM CARD -->
  <div class="max-w-5xl mx-auto bg-white rounded-xl shadow-sm p-8 md:p-10">

    <form class="space-y-6">

      <!-- Sujet -->
      <div>
        <label class="block text-sm mb-2">Quel est le sujet de votre demande ? *</label>
        <select class="w-full border rounded-md p-3 text-sm">
          <option>Choisir une option...</option>
        </select>
      </div>

      <!-- Vous êtes -->
      <div>
        <label class="block text-sm mb-2">Vous êtes *</label>
        <select class="w-1/3 border rounded-md p-3 text-sm">
          <option>Particulier</option>
        </select>
      </div>

      <!-- Nom prénom -->
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm mb-2">Prénom *</label>
          <input type="text" placeholder="Prénom"
            class="w-full border rounded-md p-3 text-sm">
        </div>
        <div>
          <label class="block text-sm mb-2">Nom *</label>
          <input type="text" placeholder="Nom"
            class="w-full border rounded-md p-3 text-sm">
        </div>
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm mb-2">Adresse email *</label>
        <input type="email" placeholder="Adresse email"
          class="w-full border rounded-md p-3 text-sm">
      </div>

      <div>
        <label class="block text-sm mb-2">Confirmer l'adresse email *</label>
        <input type="email" placeholder="Adresse email"
          class="w-full border rounded-md p-3 text-sm">
      </div>

      <!-- Téléphone -->
      <div>
        <label class="block text-sm mb-2">Téléphone</label>
        <div class="flex gap-4">
          <select class="w-1/4 border rounded-md p-3 text-sm">
            <option>France (+33)</option>
          </select>
          <input type="text"
            placeholder="Numéro de téléphone sans indicatif de pays"
            class="w-3/4 border rounded-md p-3 text-sm">
        </div>
      </div>

      <!-- Message -->
      <div>
        <label class="block text-sm mb-2">Message *</label>
        <textarea rows="5"
          placeholder="Message"
          class="w-full border rounded-md p-3 text-sm"></textarea>
        <p class="text-right text-xs text-gray-400 mt-1">
          0/5000 caractères
        </p>
      </div>

      <!-- Checkbox -->
      <div class="flex items-start gap-3 text-xs text-gray-500">
        <input type="checkbox" class="mt-1">
        <p>
          J'accepte que mon adresse email soit utilisée pour le réseau Clevacances.
          En aucun cas elle ne sera cédée à un tiers.
        </p>
      </div>

      <!-- Bouton -->
      <div class="text-right">
        <button type="submit"
          class="bg-[#bfe3de] text-[#1f7a6e] px-6 py-2 rounded-md font-semibold hover:opacity-80">
          Envoyer
        </button>
      </div>

    </form>

  </div>

  <!-- MAP -->
  <div class="max-w-5xl mx-auto mt-16">
    <img src="assets/map.png"
         alt="Carte localisation"
         class="w-full rounded-md shadow-sm">
  </div>

</section>

